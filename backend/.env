# PromptGuard — Environment Variables
# Copy this to .env and fill in your values

# OpenAI API Key (required for real LLM mode)
OPENAI_API_KEY=sk-...

# Model to use for chat responses
OPENAI_MODEL=gpt-4o-mini

# System prompt injected into every LLM request
LLM_SYSTEM_PROMPT=You are a helpful, safe, and concise AI assistant. Answer clearly and factually.

# Max tokens per LLM response
LLM_MAX_TOKENS=512
